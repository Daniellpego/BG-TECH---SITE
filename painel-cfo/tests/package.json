{
  "name": "painel-cfo-tests",
  "version": "1.0.0",
  "private": true,
  "description": "E2E, load, and regression tests for Painel CFO Dashboard",
  "scripts": {
    "test:e2e": "npx playwright test --config=playwright.config.js",
    "test:e2e:headed": "npx playwright test --config=playwright.config.js --headed",
    "test:e2e:debug": "npx playwright test --config=playwright.config.js --debug",
    "test:load": "node load/stress-test.mjs",
    "test:load:heavy": "USERS=200 DURATION=120 node load/stress-test.mjs",
    "seed": "node seed/populate.mjs",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
