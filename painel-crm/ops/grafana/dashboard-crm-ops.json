{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "CRM BG Tech — API, Agents, LLM Cost & Infrastructure monitoring",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔑 Key Metrics",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(crm_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "title": "API Latency (p95)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(crm_http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(crm_http_request_duration_seconds_count[5m]))",
          "legendFormat": "5xx rate"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "crm_agent_jobs_enqueued_total - crm_agent_jobs_completed_total",
          "legendFormat": "pending"
        }
      ],
      "title": "Agent Job Backlog",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 500000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "increase(crm_llm_tokens_used_total[24h])",
          "legendFormat": "tokens (24h)"
        }
      ],
      "title": "LLM Tokens (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📊 API Performance",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(crm_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p50 {{ route }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(crm_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{ route }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(crm_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p99 {{ route }}"
        }
      ],
      "title": "Request Latency by Route",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(crm_http_request_duration_seconds_count{status_code=~\"2..\"}[5m])) by (route)",
          "legendFormat": "2xx {{ route }}"
        },
        {
          "expr": "sum(rate(crm_http_request_duration_seconds_count{status_code=~\"4..\"}[5m])) by (route)",
          "legendFormat": "4xx {{ route }}"
        },
        {
          "expr": "sum(rate(crm_http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) by (route)",
          "legendFormat": "5xx {{ route }}"
        }
      ],
      "title": "Request Rate by Status Code",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🤖 Agent Workers",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(crm_agent_jobs_enqueued_total[5m])",
          "legendFormat": "enqueued {{ agent_name }}"
        },
        {
          "expr": "rate(crm_agent_jobs_completed_total{status=\"success\"}[5m])",
          "legendFormat": "completed {{ agent_name }}"
        }
      ],
      "title": "Job Throughput (enqueued vs completed)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 21,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(crm_agent_jobs_completed_total{status=\"error\"}[5m])",
          "legendFormat": "failed {{ agent_name }}"
        }
      ],
      "title": "Job Failures",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": {
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum(crm_agent_jobs_completed_total) by (status)",
          "legendFormat": "{{ status }}"
        }
      ],
      "title": "Job Success / Failure Ratio",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "💰 LLM Cost & Tokens",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "rate(crm_llm_tokens_used_total{direction=\"input\"}[5m]) * 300",
          "legendFormat": "input {{ model }}"
        },
        {
          "expr": "rate(crm_llm_tokens_used_total{direction=\"output\"}[5m]) * 300",
          "legendFormat": "output {{ model }}"
        }
      ],
      "title": "Token Usage Rate (per 5min)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 40 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "id": 31,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "increase(crm_llm_tokens_used_total{direction=\"output\"}[720h]) * 0.00006 + increase(crm_llm_tokens_used_total{direction=\"input\"}[720h]) * 0.00001",
          "legendFormat": "estimated cost"
        }
      ],
      "title": "Estimated Monthly LLM Cost (USD)",
      "description": "Estimate based on gpt-4o-mini pricing: $0.01/1k input, $0.06/1k output",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "id": 32,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(crm_llm_tokens_used_total[24h])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ],
      "title": "Tokens by Model (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "⚙️ Infrastructure",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 40,
      "targets": [
        {
          "expr": "crm_process_resident_memory_bytes",
          "legendFormat": "RSS"
        },
        {
          "expr": "crm_nodejs_heap_size_used_bytes",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "crm_nodejs_heap_size_total_bytes",
          "legendFormat": "Heap Total"
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 41,
      "targets": [
        {
          "expr": "crm_nodejs_eventloop_lag_seconds",
          "legendFormat": "Event Loop Lag"
        },
        {
          "expr": "crm_nodejs_eventloop_lag_p99_seconds",
          "legendFormat": "p99"
        }
      ],
      "title": "Event Loop Lag",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 42,
      "targets": [
        {
          "expr": "crm_nodejs_active_handles_total",
          "legendFormat": "Active Handles"
        },
        {
          "expr": "crm_nodejs_active_requests_total",
          "legendFormat": "Active Requests"
        }
      ],
      "title": "Active Handles & Requests",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["crm", "bgtech", "agents", "llm"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Sao_Paulo",
  "title": "CRM BG Tech — Operations",
  "uid": "crm-bgtech-ops",
  "version": 1
}
